# === Required ===

# Supabase Service Role Key (from Supabase Dashboard > Settings > API > service_role key)
# WARNING: This bypasses RLS — keep it secret!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Firebase Service Account (either as JSON string or file at data/firebase-service-account.json)
# Option A: path to service account JSON file (already in .gitignore)
#   Just place the file at: data/firebase-service-account.json
# Option B: paste the full JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"ulpro-102d3",...}

# === Optional ===

# Port (default: 3001)
PORT=3001

# API Secret Key for client-to-server auth (recommended)
# Clients must send: Authorization: Bearer <key>
API_SECRET_KEY=my-secret-key

# Supabase URL (only needed if different from default)
SUPABASE_URL=https://psoatzqqzdknrzslhvvt.supabase.co
